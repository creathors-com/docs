[{"data":1,"prerenderedAt":317},["ShallowReactive",2],{"navigation":3,"/fans/billing":50,"/fans/billing-surround":314},[4,13,20,44],{"title":5,"_path":6,"children":7},"Getting Started","/getting-started",[8,10],{"title":9,"_path":6},"Introduction",{"title":11,"_path":12},"FAQ","/getting-started/faq",{"title":14,"_path":15,"children":16},"General","/general",[17],{"title":18,"_path":19},"Account","/general/account",{"title":21,"_path":22,"children":23},"Creators","/creators",[24,26,29,32,35,38,41],{"title":18,"_path":25},"/creators/account",{"title":27,"_path":28},"Billing","/creators/billing",{"title":30,"_path":31},"Posts","/creators/posts",{"title":33,"_path":34},"Tiers","/creators/tiers",{"title":36,"_path":37},"Coupons","/creators/coupons",{"title":39,"_path":40},"Alerts","/creators/alerts",{"title":42,"_path":43},"Analytics","/creators/analytics",{"title":45,"_path":46,"children":47},"Fans / Subscribers","/fans",[48],{"title":27,"_path":49},"/fans/billing",{"_path":49,"_dir":51,"_draft":52,"_partial":52,"_locale":53,"title":27,"description":54,"body":55,"_type":308,"_id":309,"_source":310,"_file":311,"_stem":312,"_extension":313},"fans",false,"","All information about how we handle billing.",{"type":56,"children":57,"toc":294},"root",[58,77,84,89,102,107,113,118,125,130,135,141,172,178,188,193,198,204,209,215,220,259,264,270],{"type":59,"tag":60,"props":61,"children":63},"element","callout",{"icon":62},"i-heroicons-light-bulb",[64],{"type":59,"tag":65,"props":66,"children":67},"p",{},[68,71],{"type":69,"value":70},"text","This page contains information about billing for paying fans. If you are a Creator and want to know more about how we handle billing for you, go to ",{"type":59,"tag":72,"props":73,"children":74},"a",{"href":28},[75],{"type":69,"value":76},"Creator's Page",{"type":59,"tag":78,"props":79,"children":81},"h2",{"id":80},"donations",[82],{"type":69,"value":83},"Donations",{"type":59,"tag":65,"props":85,"children":86},{},[87],{"type":69,"value":88},"Donations are the simplest way to support a creator.",{"type":59,"tag":65,"props":90,"children":91},{},[92,94,100],{"type":69,"value":93},"You can donate to your creator by clicking the ",{"type":59,"tag":95,"props":96,"children":97},"strong",{},[98],{"type":69,"value":99},"Support with donation",{"type":69,"value":101}," button right under the creator's name on their page.",{"type":59,"tag":65,"props":103,"children":104},{},[105],{"type":69,"value":106},"You choose the amount you want to send to the creator, as well as the message you include with your donation.",{"type":59,"tag":78,"props":108,"children":110},{"id":109},"tiers-subscriptions",[111],{"type":69,"value":112},"Tiers / Subscriptions",{"type":59,"tag":65,"props":114,"children":115},{},[116],{"type":69,"value":117},"Tiers are subscriptions that allow you to access tier-restricted posts by creators.",{"type":59,"tag":119,"props":120,"children":122},"h3",{"id":121},"buying-a-subscription",[123],{"type":69,"value":124},"Buying a subscription",{"type":59,"tag":65,"props":126,"children":127},{},[128],{"type":69,"value":129},"Buying a subscription is easy. You can select one of the subscriptions shown at the top of the creator's page.",{"type":59,"tag":65,"props":131,"children":132},{},[133],{"type":69,"value":134},"You can also buy a subscription displayed on a locked post.",{"type":59,"tag":119,"props":136,"children":138},{"id":137},"managing-subscriptions",[139],{"type":69,"value":140},"Managing subscriptions",{"type":59,"tag":65,"props":142,"children":143},{},[144,146,164,165,170],{"type":69,"value":145},"You can view and cancel all of your subscriptions at ",{"type":59,"tag":72,"props":147,"children":151},{"href":148,"rel":149},"https://dashboard.creathors.com/payments",[150],"nofollow",[152,157,159],{"type":59,"tag":95,"props":153,"children":154},{},[155],{"type":69,"value":156},"Dashboard",{"type":69,"value":158}," > ",{"type":59,"tag":95,"props":160,"children":161},{},[162],{"type":69,"value":163},"Payments",{"type":69,"value":158},{"type":59,"tag":95,"props":166,"children":167},{},[168],{"type":69,"value":169},"Invoices",{"type":69,"value":171},".",{"type":59,"tag":78,"props":173,"children":175},{"id":174},"pay-per-view",[176],{"type":69,"value":177},"Pay-per-view",{"type":59,"tag":60,"props":179,"children":182},{"icon":180,"color":181},"i-heroicons-exclamation-triangle","amber",[183],{"type":59,"tag":65,"props":184,"children":185},{},[186],{"type":69,"value":187},"Be aware that if you buy pay-per-view to unlock a post, this doesn't guarantee permanent access to the content. The creator may still delete the post.",{"type":59,"tag":65,"props":189,"children":190},{},[191],{"type":69,"value":192},"Pay-per-view is another option to unlock a creator's post.",{"type":59,"tag":65,"props":194,"children":195},{},[196],{"type":69,"value":197},"If the creator has set up pay-per-view for a specific post, and you don't have the required tier to view it, you can use pay-per-view to unlock this specific post instead of buying a subscription.",{"type":59,"tag":78,"props":199,"children":201},{"id":200},"invoicing",[202],{"type":69,"value":203},"Invoicing",{"type":59,"tag":65,"props":205,"children":206},{},[207],{"type":69,"value":208},"For any payment you make on Creathors, we create an invoice for you.",{"type":59,"tag":119,"props":210,"children":212},{"id":211},"invoice-contents",[213],{"type":69,"value":214},"Invoice contents",{"type":59,"tag":65,"props":216,"children":217},{},[218],{"type":69,"value":219},"Invoices always contain all the information about the product you purchased, including its price and currency.",{"type":59,"tag":65,"props":221,"children":222},{},[223,225,230,232,258],{"type":69,"value":224},"The invoice includes your address, which you ",{"type":59,"tag":95,"props":226,"children":227},{},[228],{"type":69,"value":229},"must",{"type":69,"value":231}," set at ",{"type":59,"tag":72,"props":233,"children":236},{"href":234,"rel":235},"https://dashboard.creathors.com/settings/billing#address",[150],[237,241,242,247,248,252,253],{"type":59,"tag":95,"props":238,"children":239},{},[240],{"type":69,"value":156},{"type":69,"value":158},{"type":59,"tag":95,"props":243,"children":244},{},[245],{"type":69,"value":246},"Settings",{"type":69,"value":158},{"type":59,"tag":95,"props":249,"children":250},{},[251],{"type":69,"value":27},{"type":69,"value":158},{"type":59,"tag":95,"props":254,"children":255},{},[256],{"type":69,"value":257},"Address",{"type":69,"value":171},{"type":59,"tag":65,"props":260,"children":261},{},[262],{"type":69,"value":263},"Invoices also contain either your first and last name or your company name, if one is set. If you set a TAX ID for your company, it will be included as well.",{"type":59,"tag":119,"props":265,"children":267},{"id":266},"invoice-overview",[268],{"type":69,"value":269},"Invoice overview",{"type":59,"tag":65,"props":271,"children":272},{},[273,275,288,289,293],{"type":69,"value":274},"You can see the list of your invoices and your current subscriptions at ",{"type":59,"tag":72,"props":276,"children":278},{"href":148,"rel":277},[150],[279,283,284],{"type":59,"tag":95,"props":280,"children":281},{},[282],{"type":69,"value":156},{"type":69,"value":158},{"type":59,"tag":95,"props":285,"children":286},{},[287],{"type":69,"value":163},{"type":69,"value":158},{"type":59,"tag":95,"props":290,"children":291},{},[292],{"type":69,"value":169},{"type":69,"value":171},{"title":53,"searchDepth":295,"depth":295,"links":296},2,[297,298,303,304],{"id":80,"depth":295,"text":83},{"id":109,"depth":295,"text":112,"children":299},[300,302],{"id":121,"depth":301,"text":124},3,{"id":137,"depth":301,"text":140},{"id":174,"depth":295,"text":177},{"id":200,"depth":295,"text":203,"children":305},[306,307],{"id":211,"depth":301,"text":214},{"id":266,"depth":301,"text":269},"markdown","content:4.fans:1.billing.md","content","4.fans/1.billing.md","4.fans/1.billing","md",[315,316],{"_path":43,"title":42,"description":42}
[{"data":1,"prerenderedAt":120},["ShallowReactive",2],{"navigation":3,"/getting-started/faq":50,"/getting-started/faq-surround":115},[4,13,20,44],{"title":5,"_path":6,"children":7},"Getting Started","/getting-started",[8,10],{"title":9,"_path":6},"Introduction",{"title":11,"_path":12},"FAQ","/getting-started/faq",{"title":14,"_path":15,"children":16},"General","/general",[17],{"title":18,"_path":19},"Account","/general/account",{"title":21,"_path":22,"children":23},"Creators","/creators",[24,26,29,32,35,38,41],{"title":18,"_path":25},"/creators/account",{"title":27,"_path":28},"Billing","/creators/billing",{"title":30,"_path":31},"Posts","/creators/posts",{"title":33,"_path":34},"Tiers","/creators/tiers",{"title":36,"_path":37},"Coupons","/creators/coupons",{"title":39,"_path":40},"Alerts","/creators/alerts",{"title":42,"_path":43},"Analytics","/creators/analytics",{"title":45,"_path":46,"children":47},"Fans / Subscribers","/fans",[48],{"title":27,"_path":49},"/fans/billing",{"_path":12,"_dir":51,"_draft":52,"_partial":52,"_locale":53,"title":11,"description":54,"body":55,"_type":109,"_id":110,"_source":111,"_file":112,"_stem":113,"_extension":114},"getting-started",false,"","Frequently asked questions.",{"type":56,"children":57,"toc":104},"root",[58,67,73,78,83,89,94,99],{"type":59,"tag":60,"props":61,"children":63},"element","h2",{"id":62},"what-is-creathors",[64],{"type":65,"value":66},"text","What is Creathors?",{"type":59,"tag":68,"props":69,"children":70},"p",{},[71],{"type":65,"value":72},"The Creathors Platform is a place for creators of any kind to share their work with their fans, whether it be videos, images, or simple thoughts they want to share with their community.",{"type":59,"tag":68,"props":74,"children":75},{},[76],{"type":65,"value":77},"We strive to make it as easy as possible for creators to focus on what they love by giving them the ability to monetize their work through subscriptions and/or pay-per-view.",{"type":59,"tag":68,"props":79,"children":80},{},[81],{"type":65,"value":82},"Even though monetization is the main idea behind the Creathors Platform, we also offer creators the option to share their work publicly, without hiding it behind a paywall.",{"type":59,"tag":60,"props":84,"children":86},{"id":85},"what-is-pay-per-view",[87],{"type":65,"value":88},"What is pay-per-view?",{"type":59,"tag":68,"props":90,"children":91},{},[92],{"type":65,"value":93},"You might be familiar with the subscription model, where people pay a monthly fee to gain access to exclusive content. But what is pay-per-view, and how does it work?",{"type":59,"tag":68,"props":95,"children":96},{},[97],{"type":65,"value":98},"Pay-per-view allows fans to unlock a specific post by paying a one-time, often lower price, instead of subscribing at a higher price.",{"type":59,"tag":68,"props":100,"children":101},{},[102],{"type":65,"value":103},"This option is perfect for fans who want access to very specific posts and might not be interested in other content that comes with subscriptions.",{"title":53,"searchDepth":105,"depth":105,"links":106},2,[107,108],{"id":62,"depth":105,"text":66},{"id":85,"depth":105,"text":88},"markdown","content:1.getting-started:2.faq.md","content","1.getting-started/2.faq.md","1.getting-started/2.faq","md",[116,118],{"_path":6,"title":9,"description":117},"Welcome to Creathors Wiki.",{"_path":19,"title":18,"description":119},"General information about your Creathors account.",1734704906627]
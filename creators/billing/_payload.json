[{"data":1,"prerenderedAt":406},["ShallowReactive",2],{"navigation":3,"/creators/billing":65},[4,15,25,57],{"title":5,"path":6,"stem":7,"children":8},"Getting Started","/getting-started","1.getting-started/1.index",[9,11],{"title":10,"path":6,"stem":7},"Introduction",{"title":12,"path":13,"stem":14},"FAQ","/getting-started/faq","1.getting-started/2.faq",{"title":16,"path":17,"stem":18,"children":19,"page":24},"General","/general","2.general",[20],{"title":21,"path":22,"stem":23},"Account","/general/account","2.general/1.account",false,{"title":26,"path":27,"stem":28,"children":29,"page":24},"Creators","/creators","3.creators",[30,33,37,41,45,49,53],{"title":21,"path":31,"stem":32},"/creators/account","3.creators/1.account",{"title":34,"path":35,"stem":36},"Billing","/creators/billing","3.creators/2.billing",{"title":38,"path":39,"stem":40},"Posts","/creators/posts","3.creators/3.posts",{"title":42,"path":43,"stem":44},"Tiers","/creators/tiers","3.creators/4.tiers",{"title":46,"path":47,"stem":48},"Coupons","/creators/coupons","3.creators/5.coupons",{"title":50,"path":51,"stem":52},"Alerts","/creators/alerts","3.creators/6.alerts",{"title":54,"path":55,"stem":56},"Analytics","/creators/analytics","3.creators/7.analytics",{"title":58,"path":59,"stem":60,"children":61,"page":24},"Fans / Subscribers","/fans","4.fans",[62],{"title":34,"path":63,"stem":64},"/fans/billing","4.fans/1.billing",{"page":66,"surround":401},{"id":67,"title":34,"body":68,"description":395,"extension":396,"links":397,"meta":398,"navigation":399,"path":35,"seo":400,"stem":36},"docs/3.creators/2.billing.md",{"type":69,"value":70,"toc":380},"minimal",[71,83,95,100,103,119,123,131,136,139,143,146,201,204,260,264,275,279,289,302,306,313,327,361,365,372],[72,73,75],"callout",{"icon":74},"i-heroicons-light-bulb",[76,77,78,79],"p",{},"This page contains useful information for creators. If you want more information about how we handle billing for fans, head over to the ",[80,81,82],"a",{"href":63},"Fans Page",[72,84,85],{"icon":74},[76,86,87,88,94],{},"We use ",[80,89,93],{"href":90,"rel":91},"https://creathors.com",[92],"nofollow","Stripe"," for processing all payments. Most of the information on this page is based on how Stripe handles certain scenarios.",[96,97,99],"h2",{"id":98},"connecting-stripe-account","Connecting Stripe account",[76,101,102],{},"To start receiving payouts, you first need to connect a Stripe account to our platform.",[76,104,105,106,118],{},"You can easily do this by going to ",[80,107,110,114,115],{"href":108,"rel":109},"https://dashboard.creathors.com/payouts",[92],[111,112,113],"strong",{},"Dashboard"," > ",[111,116,117],{},"Payouts",", selecting your country, and following the Stripe onboarding process.",[96,120,122],{"id":121},"receiving-payouts","Receiving payouts",[76,124,125,126,130],{},"Once you have ",[80,127,129],{"href":128},"#connecting-stripe-account","connected your Stripe account"," and linked a payout option, you will be able to start receiving payouts.",[132,133,135],"h3",{"id":134},"payout-schedule","Payout schedule",[76,137,138],{},"Payouts are processed automatically at the start of each month. You can expect payouts to arrive within the first week of the month.",[132,140,142],{"id":141},"minimum-payout-threshold","Minimum payout threshold",[76,144,145],{},"To receive a payout, you must first meet the minimum threshold amount for each of your balance.",[147,148,150],"card",{"title":149},"Minimum Payout Amount per Currency",[151,152,153,166],"table",{},[154,155,156],"thead",{},[157,158,159,163],"tr",{},[160,161,162],"th",{},"Currency",[160,164,165],{},"Minimum Payout Amount",[167,168,169,178,185,193],"tbody",{},[157,170,171,175],{},[172,173,174],"td",{},"USD",[172,176,177],{},"50.00",[157,179,180,183],{},[172,181,182],{},"EUR",[172,184,177],{},[157,186,187,190],{},[172,188,189],{},"CZK",[172,191,192],{},"1,250.00",[157,194,195,198],{},[172,196,197],{},"Other",[172,199,200],{},"0.0",[76,202,203],{},"If the minimum threshold is not reached before the end of the holding period, you'll still receive your payout at the conclusion of the period.",[147,205,207,244],{"title":206},"Holding Period per Country",[151,208,209,219],{},[154,210,211],{},[157,212,213,216],{},[160,214,215],{},"Country",[160,217,218],{},"Holding Period",[167,220,221,229,237],{},[157,222,223,226],{},[172,224,225],{},"Thailand",[172,227,228],{},"10 days",[157,230,231,234],{},[172,232,233],{},"United States",[172,235,236],{},"2 years",[157,238,239,241],{},[172,240,197],{},[172,242,243],{},"90 days",[76,245,246,249,250,253,254,256,257,259],{},[111,247,248],{},"Example:","\nIf you have balance of under ",[111,251,252],{},"$50"," for ",[111,255,236],{},", and you live in the ",[111,258,233],{},",\nyou will receive a payout even though you haven't reached the required threshold.",[96,261,263],{"id":262},"taxes","Taxes",[76,265,266,267,270,271,274],{},"We are the ",[111,268,269],{},"merchant of record",", meaning we handle the collection and remittance of taxes. However, we do ",[111,272,273],{},"not"," provide tax advice or take care of tax reporting for you. You are still responsible for complying with tax regulations in your jurisdiction.",[132,276,278],{"id":277},"tax-reporting","Tax Reporting",[76,280,281,282,284,285,288],{},"As the ",[111,283,269],{},", we handle the collection of taxes on the payments made through our platform. However, ",[111,286,287],{},"we do not handle tax reporting"," for you.",[290,291,292,296],"ul",{},[293,294,295],"li",{},"We collect and remit the taxes to the appropriate authorities.",[293,297,298,301],{},[111,299,300],{},"It’s important to consult with a tax professional"," to ensure you are complying with tax laws and obligations specific to your location.",[132,303,305],{"id":304},"exclusive-tax","Exclusive tax",[76,307,308,309,312],{},"We automatically charge ",[111,310,311],{},"exclusive tax"," on all payments made through our platform. \"Exclusive tax\" means that the tax is:",[290,314,315,321],{},[293,316,317,320],{},[111,318,319],{},"Added on top"," of the price your fans pay.",[293,322,323,326],{},[111,324,325],{},"Not included"," in the price you set for your products.",[147,328,330,344],{"title":329},"Example",[290,331,332,338],{},[293,333,334,335],{},"Price you set: ",[111,336,337],{},"$10",[293,339,340,341],{},"Tax rate: ",[111,342,343],{},"10%",[76,345,346,347,350,351,354,355,357,358,360],{},"Your fans will pay ",[111,348,349],{},"$11",", which includes the ",[111,352,353],{},"$1"," tax. You will receive your cut out of the ",[111,356,337],{}," you set for your product, and the ",[111,359,353],{}," tax is withheld and remitted by us to the appropriate authorities.",[132,362,364],{"id":363},"creators-responsibility","Creator's Responsibility",[76,366,367,368,371],{},"While we are the merchant of record and handle the tax collection and remittance, ",[111,369,370],{},"you are still responsible for your taxes"," in your jurisdiction.",[290,373,374,377],{},[293,375,376],{},"This includes ensuring you comply with your local tax laws and regulations.",[293,378,379],{},"You must report and pay any taxes due to your local tax authority as required by your jurisdiction.",{"title":381,"searchDepth":382,"depth":382,"links":383},"",2,[384,385,390],{"id":98,"depth":382,"text":99},{"id":121,"depth":382,"text":122,"children":386},[387,389],{"id":134,"depth":388,"text":135},3,{"id":141,"depth":388,"text":142},{"id":262,"depth":382,"text":263,"children":391},[392,393,394],{"id":277,"depth":388,"text":278},{"id":304,"depth":388,"text":305},{"id":363,"depth":388,"text":364},"On this page, you will find everything you need to know about how we process payments and payouts.","md",null,{},true,{"title":34,"description":395},[402,404],{"title":21,"path":31,"stem":32,"description":403,"children":-1},"Creator-specific information about accounts.",{"title":38,"path":39,"stem":40,"description":405,"children":-1},"Everything you need to know about creating and editing posts.",1737121677755]
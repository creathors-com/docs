[{"data":1,"prerenderedAt":433},["ShallowReactive",2],{"navigation":3,"/creators/billing":50,"/creators/billing-surround":428},[4,13,20,44],{"title":5,"_path":6,"children":7},"Getting Started","/getting-started",[8,10],{"title":9,"_path":6},"Introduction",{"title":11,"_path":12},"FAQ","/getting-started/faq",{"title":14,"_path":15,"children":16},"General","/general",[17],{"title":18,"_path":19},"Account","/general/account",{"title":21,"_path":22,"children":23},"Creators","/creators",[24,26,29,32,35,38,41],{"title":18,"_path":25},"/creators/account",{"title":27,"_path":28},"Billing","/creators/billing",{"title":30,"_path":31},"Posts","/creators/posts",{"title":33,"_path":34},"Tiers","/creators/tiers",{"title":36,"_path":37},"Coupons","/creators/coupons",{"title":39,"_path":40},"Alerts","/creators/alerts",{"title":42,"_path":43},"Analytics","/creators/analytics",{"title":45,"_path":46,"children":47},"Fans / Subscribers","/fans",[48],{"title":27,"_path":49},"/fans/billing",{"_path":28,"_dir":51,"_draft":52,"_partial":52,"_locale":53,"title":27,"description":54,"body":55,"_type":422,"_id":423,"_source":424,"_file":425,"_stem":426,"_extension":427},"creators",false,"","On this page, you will find everything you need to know about how we process payments and payouts.",{"type":56,"children":57,"toc":408},"root",[58,77,95,102,107,132,138,151,158,163,169,174,186,205,211,230,236,254,274,280,292,315,377,383,395],{"type":59,"tag":60,"props":61,"children":63},"element","callout",{"icon":62},"i-heroicons-light-bulb",[64],{"type":59,"tag":65,"props":66,"children":67},"p",{},[68,71],{"type":69,"value":70},"text","This page contains useful information for creators. If you want more information about how we handle billing for fans, head over to the ",{"type":59,"tag":72,"props":73,"children":74},"a",{"href":49},[75],{"type":69,"value":76},"Fans Page",{"type":59,"tag":60,"props":78,"children":79},{"icon":62},[80],{"type":59,"tag":65,"props":81,"children":82},{},[83,85,93],{"type":69,"value":84},"We use ",{"type":59,"tag":72,"props":86,"children":90},{"href":87,"rel":88},"https://creathors.com",[89],"nofollow",[91],{"type":69,"value":92},"Stripe",{"type":69,"value":94}," for processing all payments. Most of the information on this page is based on how Stripe handles certain scenarios.",{"type":59,"tag":96,"props":97,"children":99},"h2",{"id":98},"connecting-stripe-account",[100],{"type":69,"value":101},"Connecting Stripe account",{"type":59,"tag":65,"props":103,"children":104},{},[105],{"type":69,"value":106},"To start receiving payouts, you first need to connect a Stripe account to our platform.",{"type":59,"tag":65,"props":108,"children":109},{},[110,112,130],{"type":69,"value":111},"You can easily do this by going to ",{"type":59,"tag":72,"props":113,"children":116},{"href":114,"rel":115},"https://dashboard.creathors.com/payouts",[89],[117,123,125],{"type":59,"tag":118,"props":119,"children":120},"strong",{},[121],{"type":69,"value":122},"Dashboard",{"type":69,"value":124}," > ",{"type":59,"tag":118,"props":126,"children":127},{},[128],{"type":69,"value":129},"Payouts",{"type":69,"value":131},", selecting your country, and following the Stripe onboarding process.",{"type":59,"tag":96,"props":133,"children":135},{"id":134},"receiving-payouts",[136],{"type":69,"value":137},"Receiving payouts",{"type":59,"tag":65,"props":139,"children":140},{},[141,143,149],{"type":69,"value":142},"Once you have ",{"type":59,"tag":72,"props":144,"children":146},{"href":145},"#connecting-stripe-account",[147],{"type":69,"value":148},"connected your Stripe account",{"type":69,"value":150}," and linked a payout option, you will be able to start receiving payouts.",{"type":59,"tag":152,"props":153,"children":155},"h3",{"id":154},"payout-schedule",[156],{"type":69,"value":157},"Payout schedule",{"type":59,"tag":65,"props":159,"children":160},{},[161],{"type":69,"value":162},"Payouts are processed automatically at the start of each month. You can expect payouts to arrive within the first week of the month.",{"type":59,"tag":152,"props":164,"children":166},{"id":165},"payout-ready-payments",[167],{"type":69,"value":168},"Payout ready payments",{"type":59,"tag":65,"props":170,"children":171},{},[172],{"type":69,"value":173},"When you receive a payment, there is a 7-day delay before the funds are ready to be paid out. This delay is primarily for fraud and dispute protection.",{"type":59,"tag":65,"props":175,"children":176},{},[177,179,184],{"type":69,"value":178},"All payments are available for payout ",{"type":59,"tag":118,"props":180,"children":181},{},[182],{"type":69,"value":183},"7 days",{"type":69,"value":185}," after they are charged.",{"type":59,"tag":65,"props":187,"children":188},{},[189,191,196,198,203],{"type":69,"value":190},"For example, if you receive a payment on the ",{"type":59,"tag":118,"props":192,"children":193},{},[194],{"type":69,"value":195},"1st",{"type":69,"value":197}," of the month, it will be available for payout on the ",{"type":59,"tag":118,"props":199,"children":200},{},[201],{"type":69,"value":202},"8th",{"type":69,"value":204}," of the month.",{"type":59,"tag":96,"props":206,"children":208},{"id":207},"taxes",[209],{"type":69,"value":210},"Taxes",{"type":59,"tag":65,"props":212,"children":213},{},[214,216,221,223,228],{"type":69,"value":215},"We are the ",{"type":59,"tag":118,"props":217,"children":218},{},[219],{"type":69,"value":220},"merchant of record",{"type":69,"value":222},", meaning we handle the collection and remittance of taxes. However, we do ",{"type":59,"tag":118,"props":224,"children":225},{},[226],{"type":69,"value":227},"not",{"type":69,"value":229}," provide tax advice or take care of tax reporting for you. You are still responsible for complying with tax regulations in your jurisdiction.",{"type":59,"tag":152,"props":231,"children":233},{"id":232},"tax-reporting",[234],{"type":69,"value":235},"Tax Reporting",{"type":59,"tag":65,"props":237,"children":238},{},[239,241,245,247,252],{"type":69,"value":240},"As the ",{"type":59,"tag":118,"props":242,"children":243},{},[244],{"type":69,"value":220},{"type":69,"value":246},", we handle the collection of taxes on the payments made through our platform. However, ",{"type":59,"tag":118,"props":248,"children":249},{},[250],{"type":69,"value":251},"we do not handle tax reporting",{"type":69,"value":253}," for you.",{"type":59,"tag":255,"props":256,"children":257},"ul",{},[258,264],{"type":59,"tag":259,"props":260,"children":261},"li",{},[262],{"type":69,"value":263},"We collect and remit the taxes to the appropriate authorities.",{"type":59,"tag":259,"props":265,"children":266},{},[267,272],{"type":59,"tag":118,"props":268,"children":269},{},[270],{"type":69,"value":271},"It’s important to consult with a tax professional",{"type":69,"value":273}," to ensure you are complying with tax laws and obligations specific to your location.",{"type":59,"tag":152,"props":275,"children":277},{"id":276},"exclusive-tax",[278],{"type":69,"value":279},"Exclusive tax",{"type":59,"tag":65,"props":281,"children":282},{},[283,285,290],{"type":69,"value":284},"We automatically charge ",{"type":59,"tag":118,"props":286,"children":287},{},[288],{"type":69,"value":289},"exclusive tax",{"type":69,"value":291}," on all payments made through our platform. \"Exclusive tax\" means that the tax is:",{"type":59,"tag":255,"props":293,"children":294},{},[295,305],{"type":59,"tag":259,"props":296,"children":297},{},[298,303],{"type":59,"tag":118,"props":299,"children":300},{},[301],{"type":69,"value":302},"Added on top",{"type":69,"value":304}," of the price your fans pay.",{"type":59,"tag":259,"props":306,"children":307},{},[308,313],{"type":59,"tag":118,"props":309,"children":310},{},[311],{"type":69,"value":312},"Not included",{"type":69,"value":314}," in the price you set for your products.",{"type":59,"tag":316,"props":317,"children":319},"card",{"title":318},"Example",[320,346],{"type":59,"tag":255,"props":321,"children":322},{},[323,333],{"type":59,"tag":259,"props":324,"children":325},{},[326,328],{"type":69,"value":327},"Price you set: ",{"type":59,"tag":118,"props":329,"children":330},{},[331],{"type":69,"value":332},"$10",{"type":59,"tag":259,"props":334,"children":335},{},[336,338,344],{"type":69,"value":337},"Tax rate: *",{"type":59,"tag":339,"props":340,"children":341},"em",{},[342],{"type":69,"value":343},"10%",{"type":69,"value":345},"*",{"type":59,"tag":65,"props":347,"children":348},{},[349,351,356,358,363,365,369,371,375],{"type":69,"value":350},"Your fans will pay *",{"type":59,"tag":339,"props":352,"children":353},{},[354],{"type":69,"value":355},"$11",{"type":69,"value":357},"*, which includes the *",{"type":59,"tag":339,"props":359,"children":360},{},[361],{"type":69,"value":362},"$1",{"type":69,"value":364},"* tax. You will receive your cut out of the *",{"type":59,"tag":339,"props":366,"children":367},{},[368],{"type":69,"value":332},{"type":69,"value":370},"* you set for your product, and the ",{"type":59,"tag":118,"props":372,"children":373},{},[374],{"type":69,"value":362},{"type":69,"value":376}," tax is withheld and remitted by us to the appropriate authorities.",{"type":59,"tag":152,"props":378,"children":380},{"id":379},"creators-responsibility",[381],{"type":69,"value":382},"Creator's Responsibility",{"type":59,"tag":65,"props":384,"children":385},{},[386,388,393],{"type":69,"value":387},"While we are the merchant of record and handle the tax collection and remittance, ",{"type":59,"tag":118,"props":389,"children":390},{},[391],{"type":69,"value":392},"you are still responsible for your taxes",{"type":69,"value":394}," in your jurisdiction.",{"type":59,"tag":255,"props":396,"children":397},{},[398,403],{"type":59,"tag":259,"props":399,"children":400},{},[401],{"type":69,"value":402},"This includes ensuring you comply with your local tax laws and regulations.",{"type":59,"tag":259,"props":404,"children":405},{},[406],{"type":69,"value":407},"You must report and pay any taxes due to your local tax authority as required by your jurisdiction.",{"title":53,"searchDepth":409,"depth":409,"links":410},2,[411,412,417],{"id":98,"depth":409,"text":101},{"id":134,"depth":409,"text":137,"children":413},[414,416],{"id":154,"depth":415,"text":157},3,{"id":165,"depth":415,"text":168},{"id":207,"depth":409,"text":210,"children":418},[419,420,421],{"id":232,"depth":415,"text":235},{"id":276,"depth":415,"text":279},{"id":379,"depth":415,"text":382},"markdown","content:3.creators:2.billing.md","content","3.creators/2.billing.md","3.creators/2.billing","md",[429,431],{"_path":25,"title":18,"description":430},"Creator-specific information about accounts.",{"_path":31,"title":30,"description":432},"Everything you need to know about creating and editing posts.",1734692670758]
9,"value":84},"We use ",{"type":59,"tag":72,"props":86,"children":90},{"href":87,"rel":88},"https://creathors.com",[89],"nofollow",[91],{"type":69,"value":92},"Stripe",{"type":69,"value":94}," for processing all payments. Most of the information on this page is based on how Stripe handles certain scenarios.",{"type":59,"tag":96,"props":97,"children":99},"h2",{"id":98},"connecting-stripe-account",[100],{"type":69,"value":101},"Connecting Stripe account",{"type":59,"tag":65,"props":103,"children":104},{},[105],{"type":69,"value":106},"To start receiving payouts, you first need to connect a Stripe account to our platform.",{"type":59,"tag":65,"props":108,"children":109},{},[110,112,130],{"type":69,"value":111},"You can easily do this by going to ",{"type":59,"tag":72,"props":113,"children":116},{"href":114,"rel":115},"https://dashboard.creathors.com/payouts",[89],[117,123,125],{"type":59,"tag":118,"props":119,"children":120},"strong",{},[121],{"type":69,"value":122},"Dashboard",{"type":69,"value":124}," > ",{"type":59,"tag":118,"props":126,"children":127},{},[128],{"type":69,"value":129},"Payouts",{"type":69,"value":131},", selecting your country, and following the Stripe onboarding process.",{"type":59,"tag":96,"props":133,"children":135},{"id":134},"receiving-payouts",[136],{"type":69,"value":137},"Receiving payouts",{"type":59,"tag":65,"props":139,"children":140},{},[141,143,149],{"type":69,"value":142},"Once you have ",{"type":59,"tag":72,"props":144,"children":146},{"href":145},"#connecting-stripe-account",[147],{"type":69,"value":148},"connected your Stripe account",{"type":69,"value":150}," and linked a payout option, you will be able to start receiving payouts.",{"type":59,"tag":152,"props":153,"children":155},"h3",{"id":154},"payout-schedule",[156],{"type":69,"value":157},"Payout schedule",{"type":59,"tag":65,"props":159,"children":160},{},[161],{"type":69,"value":162},"Payouts are processed automatically at the start of each month. You can expect payouts to arrive within the first week of the month.",{"type":59,"tag":152,"props":164,"children":166},{"id":165},"minimum-payout-threshold",[167],{"type":69,"value":168},"Minimum payout threshold",{"type":59,"tag":65,"props":170,"children":171},{},[172],{"type":69,"value":173},"To receive a payout, you must first meet the minimum threshold amount for each of your balance.",{"type":59,"tag":175,"props":176,"children":178},"card",{"title":177},"Minimum Payout Amount per Currency",[179],{"type":59,"tag":180,"props":181,"children":182},"table",{},[183,202],{"type":59,"tag":184,"props":185,"children":186},"thead",{},[187],{"type":59,"tag":188,"props":189,"children":190},"tr",{},[191,197],{"type":59,"tag":192,"props":193,"children":194},"th",{},[195],{"type":69,"value":196},"Currency",{"type":59,"tag":192,"props":198,"children":199},{},[200],{"type":69,"value":201},"Minimum Payout Amount",{"type":59,"tag":203,"props":204,"children":205},"tbody",{},[206,220,232,245],{"type":59,"tag":188,"props":207,"children":208},{},[209,215],{"type":59,"tag":210,"props":211,"children":212},"td",{},[213],{"type":69,"value":214},"USD",{"type":59,"tag":210,"props":216,"children":217},{},[218],{"type":69,"value":219},"50.00",{"type":59,"tag":188,"props":221,"children":222},{},[223,228],{"type":59,"tag":210,"props":224,"children":225},{},[226],{"type":69,"value":227},"EUR",{"type":59,"tag":210,"props":229,"children":230},{},[231],{"type":69,"value":219},{"type":59,"tag":188,"props":233,"children":234},{},[235,240],{"type":59,"tag":210,"props":236,"children":237},{},[238],{"type":69,"value":239},"CZK",{"type":59,"tag":210,"props":241,"children":242},{},[243],{"type":69,"value":244},"1,250.00",{"type":59,"tag":188,"props":246,"children":247},{},[248,253],{"type":59,"tag":210,"props":249,"children":250},{},[251],{"type":69,"value":252},"Other",{"type":59,"tag":210,"props":254,"children":255},{},[256],{"type":69,"value":257},"0.0",{"type":59,"tag":65,"props":259,"children":260},{},[261],{"type":69,"value":262},"If the minimum threshold is not reached before the end of the holding period, you'll still receive your payout at the conclusion of the period.",{"type":59,"tag":175,"props":264,"children":266},{"title":265},"Holding Period per Country",[267,327],{"type":59,"tag":180,"props":268,"children":269},{},[270,286],{"type":59,"tag":184,"props":271,"children":272},{},[273],{"type":59,"tag":188,"props":274,"children":275},{},[276,281],{"type":59,"tag":192,"props":277,"children":278},{},[279],{"type":69,"value":280},"Country",{"type":59,"tag":192,"props":282,"children":283},{},[284],{"type":69,"value":285},"Holding Period",{"type":59,"tag":203,"props":287,"children":288},{},[289,302,315],{"type":59,"tag":188,"props":290,"children":291},{},[292,297],{"type":59,"tag":210,"props":293,"children":294},{},[295],{"type":69,"value":296},"Thailand",{"type":59,"tag":210,"props":298,"children":299},{},[300],{"type":69,"value":301},"10 days",{"type":59,"tag":188,"props":303,"children":304},{},[305,310],{"type":59,"tag":210,"props":306,"children":307},{},[308],{"type":69,"value":309},"United States",{"type":59,"tag":210,"props":311,"children":312},{},[313],{"type":69,"value":314},"2 years",{"type":59,"tag":188,"props":316,"children":317},{},[318,322],{"type":59,"tag":210,"props":319,"children":320},{},[321],{"type":69,"value":252},{"type":59,"tag":210,"props":323,"children":324},{},[325],{"type":69,"value":326},"90 days",{"type":59,"tag":65,"props":328,"children":329},{},[330,335,337,342,344,348,350,354],{"type":59,"tag":118,"props":331,"children":332},{},[333],{"type":69,"value":334},"Example:",{"type":69,"value":336},"\nIf you have balance of under ",{"type":59,"tag":118,"props":338,"children":339},{},[340],{"type":69,"value":341},"$50",{"type":69,"value":343}," for ",{"type":59,"tag":118,"props":345,"children":346},{},[347],{"type":69,"value":314},{"type":69,"value":349},", and you live in the ",{"type":59,"tag":118,"props":351,"children":352},{},[353],{"type":69,"value":309},{"type":69,"value":355},",\nyou will receive a payout even though you haven't reached the required threshold.",{"type":59,"tag":96,"props":357,"children":359},{"id":358},"taxes",[360],{"type":69,"value":361},"Taxes",{"type":59,"tag":65,"props":363,"children":364},{},[365,367,372,374,379],{"type":69,"value":366},"We are the ",{"type":59,"tag":118,"props":368,"children":369},{},[370],{"type":69,"value":371},"merchant of record",{"type":69,"value":373},", meaning we handle the collection and remittance of taxes. However, we do ",{"type":59,"tag":118,"props":375,"children":376},{},[377],{"type":69,"value":378},"not",{"type":69,"value":380}," provide tax advice or take care of tax reporting for you. You are still responsible for complying with tax regulations in your jurisdiction.",{"type":59,"tag":152,"props":382,"children":384},{"id":383},"tax-reporting",[385],{"type":69,"value":386},"Tax Reporting",{"type":59,"tag":65,"props":388,"children":389},{},[390,392,396,398,403],{"type":69,"value":391},"As the ",{"type":59,"tag":118,"props":393,"children":394},{},[395],{"type":69,"value":371},{"type":69,"value":397},", we handle the collection of taxes on the payments made through our platform. However, ",{"type":59,"tag":118,"props":399,"children":400},{},[401],{"type":69,"value":402},"we do not handle tax reporting",{"type":69,"value":404}," for you.",{"type":59,"tag":406,"props":407,"children":408},"ul",{},[409,415],{"type":59,"tag":410,"props":411,"children":412},"li",{},[413],{"type":69,"value":414},"We collect and remit the taxes to the appropriate authorities.",{"type":59,"tag":410,"props":416,"children":417},{},[418,423],{"type":59,"tag":118,"props":419,"children":420},{},[421],{"type":69,"value":422},"It’s important to consult with a tax professional",{"type":69,"value":424}," to ensure you are complying with tax laws and obligations specific to your location.",{"type":59,"tag":152,"props":426,"children":428},{"id":427},"exclusive-tax",[429],{"type":69,"value":430},"Exclusive tax",{"type":59,"tag":65,"props":432,"children":433},{},[434,436,441],{"type":69,"value":435},"We automatically charge ",{"type":59,"tag":118,"props":437,"children":438},{},[439],{"type":69,"value":440},"exclusive tax",{"type":69,"value":442}," on all payments made through our platform. \"Exclusive tax\" means that the tax is:",{"type":59,"tag":406,"props":444,"children":445},{},[446,456],{"type":59,"tag":410,"props":447,"children":448},{},[449,454],{"type":59,"tag":118,"props":450,"children":451},{},[452],{"type":69,"value":453},"Added on top",{"type":69,"value":455}," of the price your fans pay.",{"type":59,"tag":410,"props":457,"children":458},{},[459,464],{"type":59,"tag":118,"props":460,"children":461},{},[462],{"type":69,"value":463},"Not included",{"type":69,"value":465}," in the price you set for your products.",{"type":59,"tag":175,"props":467,"children":469},{"title":468},"Example",[470,493],{"type":59,"tag":406,"props":471,"children":472},{},[473,483],{"type":59,"tag":410,"props":474,"children":475},{},[476,478],{"type":69,"value":477},"Price you set: ",{"type":59,"tag":118,"props":479,"children":480},{},[481],{"type":69,"value":482},"$10",{"type":59,"tag":410,"props":484,"children":485},{},[486,488],{"type":69,"value":487},"Tax rate: ",{"type":59,"tag":118,"props":489,"children":490},{},[491],{"type":69,"value":492},"10%",{"type":59,"tag":65,"props":494,"children":495},{},[496,498,503,505,510,512,516,518,522],{"type":69,"value":497},"Your fans will pay ",{"type":59,"tag":118,"props":499,"children":500},{},[501],{"type":69,"value":502},"$11",{"type":69,"value":504},", which includes the ",{"type":59,"tag":118,"props":506,"children":507},{},[508],{"type":69,"value":509},"$1",{"type":69,"value":511},"; tax. You will receive your cut out of the ",{"type":59,"tag":118,"props":513,"children":514},{},[515],{"type":69,"value":482},{"type":69,"value":517}," you set for your product, and the ",{"type":59,"tag":118,"props":519,"children":520},{},[521],{"type":69,"value":509},{"type":69,"value":523}," tax is withheld and remitted by us to the appropriate authorities.",{"type":59,"tag":152,"props":525,"children":527},{"id":526},"creators-responsibility",[528],{"type":69,"value":529},"Creator's Responsibility",{"type":59,"tag":65,"props":531,"children":532},{},[533,535,540],{"type":69,"value":534},"While we are the merchant of record and handle the tax collection and remittance, ",{"type":59,"tag":118,"props":536,"children":537},{},[538],{"type":69,"value":539},"you are still responsible for your taxes",{"type":69,"value":541}," in your jurisdiction.",{"type":59,"tag":406,"props":543,"children":544},{},[545,550],{"type":59,"tag":410,"props":546,"children":547},{},[548],{"type":69,"value":549},"This includes ensuring you comply with your local tax laws and regulations.",{"type":59,"tag":410,"props":551,"children":552},{},[553],{"type":69,"value":554},"You must report and pay any taxes due to your local tax authority as required by your jurisdiction.",{"title":53,"searchDepth":556,"depth":556,"links":557},2,[558,559,564],{"id":98,"depth":556,"text":101},{"id":134,"depth":556,"text":137,"children":560},[561,563],{"id":154,"depth":562,"text":157},3,{"id":165,"depth":562,"text":168},{"id":358,"depth":556,"text":361,"children":565},[566,567,568],{"id":383,"depth":562,"text":386},{"id":427,"depth":562,"text":430},{"id":526,"depth":562,"text":529},"markdown","content:3.creators:2.billing.md","content","3.creators/2.billing.md","3.creators/2.billing","md",[576,578],{"_path":25,"title":18,"description":577},"Creator-specific information about accounts.",{"_path":31,"title":30,"description":579},"Everything you need to know about creating and editing posts.",1736709757976]
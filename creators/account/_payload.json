e":90},"Account tags are used for better filtering on the discovery page, as well as displaying the main focus of your creator's page.",{"type":59,"tag":92,"props":93,"children":95},"h3",{"id":94},"main-tag",[96],{"type":69,"value":97},"Main Tag",{"type":59,"tag":65,"props":99,"children":100},{},[101],{"type":69,"value":102},"The main tag is the one tag that will be displayed right under your name. It should reflect the primary focus of your content.",{"type":59,"tag":92,"props":104,"children":106},{"id":105},"additional-tags",[107],{"type":69,"value":108},"Additional Tags",{"type":59,"tag":60,"props":110,"children":111},{"icon":62},[112],{"type":59,"tag":65,"props":113,"children":114},{},[115],{"type":69,"value":116},"You don't have to include the main tag again; it's automatically used for filtering.",{"type":59,"tag":65,"props":118,"children":119},{},[120],{"type":69,"value":121},"Other tags are used for filtering on the discovery page. Use all the tags you would like to be recognized by to attract a potential new audience.",{"type":59,"tag":80,"props":123,"children":125},{"id":124},"socials",[126],{"type":69,"value":127},"Socials",{"type":59,"tag":60,"props":129,"children":130},{"icon":62},[131],{"type":59,"tag":65,"props":132,"children":133},{},[134,136,142],{"type":69,"value":135},"Do you have any other social accounts you would like to connect? Let us know at ",{"type":59,"tag":72,"props":137,"children":139},{"href":138},"mailto:support@creathors.com",[140],{"type":69,"value":141},"support@creathors.com",{"type":69,"value":143},", and we will add them for you.",{"type":59,"tag":65,"props":145,"children":146},{},[147],{"type":69,"value":148},"Socials are links to other social media accounts that will be displayed under your name.",{"type":59,"tag":65,"props":150,"children":151},{},[152],{"type":69,"value":153},"You can include either the name of your account or the entire URL; we will handle the formatting for you.",{"type":59,"tag":80,"props":155,"children":1
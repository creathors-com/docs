e":90},"Account tags are used for better filtering on the discovery page, as well as displaying the main focus of your creator's page.",{"type":59,"tag":92,"props":93,"children":95},"h3",{"id":94},"main-tag",[96],{"type":69,"value":97},"Main Tag",{"type":59,"tag":65,"props":99,"children":100},{},[101],{"type":69,"value":102},"The main tag is the one tag that will be displayed right under your name. It should reflect the primary focus of your content.",{"type":59,"tag":92,"props":104,"children":106},{"id":105},"additional-tags",[107],{"type":69,"value":108},"Additional Tags",{"type":59,"tag":60,"props":110,"children":111},{"icon":62},[112],{"type":59,"tag":65,"props":113,"children":114},{},[115],{"type":69,"value":116},"You don't have to include the main tag again; it's automatically used for filtering.",{"type":59,"tag":65,"props":118,"children":119},{},[120],{"type":69,"value":121},"Other tags are used for filtering on the discovery page. Use all the tags you would like to be recognized by to attract a potential new audience.",{"type":59,"tag":80,"props":123,"children":125},{"id":124},"socials",[126],{"type":69,"value":127},"Socials",{"type":59,"tag":60,"props":129,"children":130},{"icon":62},[131],{"type":59,"tag":65,"props":132,"children":133},{},[134,136,142],{"type":69,"value":135},"Do you have any other social accounts you would like to connect? Let us know at ",{"type":59,"tag":72,"props":137,"children":139},{"href":138},"mailto:support@creathors.com",[140],{"type":69,"value":141},"support@creathors.com",{"type":69,"value":143},", and we will add them for you.",{"type":59,"tag":65,"props":145,"children":146},{},[147],{"type":69,"value":148},"Socials are links to other social media accounts that will be displayed under your name.",{"type":59,"tag":65,"props":150,"children":151},{},[152],{"type":69,"value":153},"You can include either the name of your account or the entire URL; we will handle the formatting for you.",{"type":59,"tag":80,"props":155,"children":157},{"id":156},"picture-and-background",[158],{"type":69,"value":159},"Picture and Background",{"type":59,"tag":65,"props":161,"children":162},{},[163],{"type":69,"value":164},"You can upload your own profile picture and background, but make sure they have the correct size, otherwise, they might look stretched.",{"type":59,"tag":166,"props":167,"children":168},"card",{},[169],{"type":59,"tag":170,"props":171,"children":172},"table",{},[173,192],{"type":59,"tag":174,"props":175,"children":176},"thead",{},[177],{"type":59,"tag":178,"props":179,"children":180},"tr",{},[181,187],{"type":59,"tag":182,"props":183,"children":184},"th",{},[185],{"type":69,"value":186},"Type",{"type":59,"tag":182,"props":188,"children":189},{},[190],{"type":69,"value":191},"Recommended Size",{"type":59,"tag":193,"props":194,"children":195},"tbody",{},[196,210],{"type":59,"tag":178,"props":197,"children":198},{},[199,205],{"type":59,"tag":200,"props":201,"children":202},"td",{},[203],{"type":69,"value":204},"Picture",{"type":59,"tag":200,"props":206,"children":207},{},[208],{"type":69,"value":209},"240x240",{"type":59,"tag":178,"props":211,"children":212},{},[213,218],{"type":59,"tag":200,"props":214,"children":215},{},[216],{"type":69,"value":217},"Background",{"type":59,"tag":200,"props":219,"children":220},{},[221],{"type":69,"value":222},"1920x330",{"type":59,"tag":80,"props":224,"children":226},{"id":225},"username-and-description",[227],{"type":69,"value":228},"Username and Description",{"type":59,"tag":65,"props":230,"children":231},{},[232],{"type":69,"value":233},"You can choose any username and description you want, but the username must be unique.",{"type":59,"tag":65,"props":235,"children":236},{},[237],{"type":69,"value":238},"Changing your username will also change the link to your creator's page.",{"type":59,"tag":240,"props":241,"children":243},"h1",{"id":242},"discovery-page",[244],{"type":69,"value":245},"Discovery Page",{"type":59,"tag":65,"props":247,"children":248},{},[24
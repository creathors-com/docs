text","value":"$1"}]},{"type":"text","value":"; tax. You will receive your cut out of the "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"$10"}]},{"type":"text","value":" you set for your product, and the "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"$1"}]},{"type":"text","value":" tax is withheld and remitted by us to the appropriate authorities."}]}]},{"type":"element","tag":"h3","props":{"id":"creators-responsibility"},"children":[{"type":"text","value":"Creator's Responsibility"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"While we are the merchant of record and handle the tax collection and remittance, "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"you are still responsible for your taxes"}]},{"type":"text","value":" in your jurisdiction."}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"This includes ensuring you comply with your local tax laws and regulations."}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"You must report and pay any taxes due to your local tax authority as required by your jurisdiction."}]}]}],"toc":{"title":"","searchDepth":2,"depth":2,"links":[{"id":"connecting-stripe-account","depth":2,"text":"Connecting Stripe account"},{"id":"receiving-payouts","depth":2,"text":"Receiving payouts","children":[{"id":"payout-schedule","depth":3,"text":"Payout schedule"},{"id":"minimum-payout-threshold","depth":3,"text":"Minimum payout threshold"}]},{"id":"taxes","depth":2,"text":"Taxes","children":[{"id":"tax-reporting","depth":3,"text":"Tax Reporting"},{"id":"exclusive-tax","depth":3,"text":"Exclusive tax"},{"id":"creators-responsibility","depth":3,"text":"Creator's Responsibility"}]}]}},"_type":"markdown","_id":"content:3.creators:2.billing.md","_source":"content","_file":"3.creators/2.billing.md","_st